#!/usr/bin/env node
const { spawn, execSync } = require("child_process");
const path = require("path");
const fs = require("fs");
const os = require("os");
const isWindows = process.platform === "win32";
const { MasterTokenManager } = require("../src/master/master-main");
const { version: CLI_VERSION } = require("../package.json");

const HOME = os.homedir();
const DESKTOP_DIR = path.join(HOME, "Desktop");
const GLOBAL_CONFIG_FILE = path.join(HOME, "global.json");
const STATE_FILE = path.join(HOME, ".cicy-cluster.json");
const LOGS_DIR = path.join(HOME, "logs");
const PACKAGE_ROOT = path.join(__dirname, "..");
const MASTER_ENTRY = path.join(PACKAGE_ROOT, "src", "master", "master-main.js");
const PROJECT_COMMAND_FILE = path.join(PACKAGE_ROOT, "cicy-dektop.command");
const DESKTOP_COMMAND_FILE = path.join(DESKTOP_DIR, "cicy-dektop.command");
const DEFAULT_MASTER_PORT = 8100;
const DEFAULT_WORKER_PORT = 8101;
const READY_TIMEOUT_MS = 15000;
const SHUTDOWN_TIMEOUT_MS = 5000;

const args = process.argv.slice(2);

let command = "start";
let useCNMirror = false;
let runUpdate = false;
let showVersion = false;
let masterPort = Number(process.env.MASTER_PORT || DEFAULT_MASTER_PORT);
let workerPort = Number(process.env.PORT || DEFAULT_WORKER_PORT);

for (let i = 0; i < args.length; i++) {
  const arg = args[i];
  if (arg === "-h" || arg === "--help") {
    showHelp();
    process.exit(0);
  } else if (arg === "-v" || arg === "--version") {
    showVersion = true;
  } else if (arg === "-j" || arg === "--json") {
    console.error("❌ --json is only supported by cicy-rpc");
    process.exit(1);
  } else if (arg === "-cn" || arg === "--cn") {
    useCNMirror = true;
  } else if (arg === "-u" || arg === "--update") {
    runUpdate = true;
  } else if (arg === "--master-port" && args[i + 1]) {
    masterPort = Number(args[++i]);
  } else if (arg.startsWith("--master-port=")) {
    masterPort = Number(arg.split("=")[1]);
  } else if (arg === "--port" && args[i + 1]) {
    workerPort = Number(args[++i]);
  } else if (arg.startsWith("--port=")) {
    workerPort = Number(arg.split("=")[1]);
  } else if (!arg.startsWith("-") && command === "start") {
    // First positional arg is the command; the rest are command args
    command = arg;
  }
}

if (!Number.isFinite(masterPort) || masterPort <= 0) {
  console.error("❌ Invalid --master-port value");
  process.exit(1);
}

if (!Number.isFinite(workerPort) || workerPort <= 0) {
  console.error("❌ Invalid --port value");
  process.exit(1);
}

if (showVersion) {
  console.log(`cicy version ${CLI_VERSION}`);
  process.exit(0);
}

if (useCNMirror) {
  try {
    execSync("npm config set registry https://registry.npmmirror.com", { stdio: "inherit" });
    console.log("📦 Using CN npm mirror: https://registry.npmmirror.com");
  } catch (err) {
    console.error("❌ Failed to set npm mirror:", err.message);
  }
}

if (runUpdate) {
  update();
} else {
  executeCommand(command);
}

function showHelp() {
  console.log(`cicy - Electron MCP Controller

Usage: cicy [command] [options]

Desktop commands:
  start                    Start cicy worker in foreground (default)
  stop                     Stop the running cicy worker
  status                   Show cicy worker status
  restart                  Restart the cicy worker
  logs                     Follow worker logs

Options:
  -h, --help               Show this help message
  -v, --version            Show version
  -cn                      Use CN npm mirror
  -u, --update             Update cicy to latest version
  --master-port <port>     Master port for cluster mode (default: 8100)
  --port <port>            Worker port for cluster mode (default: 8101)

Examples:
  cicy
  cicy status
  cicy restart
  cicy logs
  cicy --port 8201

RPC commands moved to: cicy-rpc`);
}

function update() {
  console.log("🔄 Updating cicy...");
  try {
    execSync("git pull", { cwd: PACKAGE_ROOT, stdio: "inherit" });
    execSync("npm install", { cwd: PACKAGE_ROOT, stdio: "inherit" });
    console.log("✅ cicy updated successfully");
  } catch (err) {
    console.error("❌ Update failed:", err.message);
    process.exit(1);
  }
}

function parsePid(value) {
  const pid = Number(value);
  return Number.isInteger(pid) && pid > 0 ? pid : null;
}

function findPidByPort(port) {
  try {
    const output = execSync(`lsof -tiTCP:${port} -sTCP:LISTEN`, {
      stdio: ["ignore", "pipe", "ignore"],
    })
      .toString()
      .trim()
      .split(/\r?\n/)
      .find(Boolean);
    return parsePid(output);
  } catch {
    return null;
  }
}

function readClusterState() {
  try {
    const raw = fs.readFileSync(STATE_FILE, "utf8");
    const state = JSON.parse(raw);
    return {
      masterPid: parsePid(state.masterPid),
      workerPid: parsePid(state.workerPid),
      masterPort: Number(state.masterPort) || DEFAULT_MASTER_PORT,
      workerPort: Number(state.workerPort) || DEFAULT_WORKER_PORT,
      tokenPath: state.tokenPath || null,
      startedAt: state.startedAt || null,
    };
  } catch {
    return null;
  }
}

function writeClusterState(state) {
  fs.writeFileSync(
    STATE_FILE,
    JSON.stringify(
      {
        ...state,
        updatedAt: new Date().toISOString(),
      },
      null,
      2
    )
  );
}

function clearClusterState() {
  if (fs.existsSync(STATE_FILE)) {
    fs.unlinkSync(STATE_FILE);
  }
}

function getRunningClusterState() {
  const state = readClusterState();
  const masterPortFromState = state?.masterPort || masterPort;
  const workerPortFromState = state?.workerPort || workerPort;
  const masterPid = state?.masterPid || findPidByPort(masterPortFromState);
  const workerPid = state?.workerPid || findPidByPort(workerPortFromState);
  const masterRunning = isRunning(masterPid);
  const workerRunning = isRunning(workerPid);

  if (!masterRunning && !workerRunning) {
    clearClusterState();
    return null;
  }

  const nextState = {
    masterPid: masterRunning ? masterPid : null,
    workerPid: workerRunning ? workerPid : null,
    masterPort: masterPortFromState,
    workerPort: workerPortFromState,
    tokenPath: state?.tokenPath || null,
    startedAt: state?.startedAt || null,
    masterRunning,
    workerRunning,
  };

  writeClusterState(nextState);
  return nextState;
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

async function stopPid(pid, label) {
  if (!pid || !isRunning(pid)) {
    return false;
  }

  try {
    process.kill(pid, "SIGTERM");
  } catch (error) {
    console.error(`❌ Failed to stop ${label}: ${error.message}`);
    return false;
  }

  for (let i = 0; i < 20; i++) {
    if (!isRunning(pid)) {
      return true;
    }
    await sleep(200);
  }

  try {
    process.kill(pid, "SIGKILL");
    return true;
  } catch (error) {
    console.error(`❌ Failed to force stop ${label}: ${error.message}`);
    return false;
  }
}

function killListenersByPort(port) {
  if (!Number.isFinite(port) || port <= 0) return;

  try {
    if (isWindows) {
      // Best-effort: kill LISTENING processes on the port
      execSync(
        `powershell -NoProfile -Command "Get-NetTCPConnection -LocalPort ${port} -State Listen -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess | Sort-Object -Unique | ForEach-Object { Stop-Process -Id $_ -Force }"`,
        { stdio: ["ignore", "ignore", "ignore"] }
      );
      return;
    }

    const pid = findPidByPort(port);
    if (pid) {
      try {
        process.kill(pid, "SIGKILL");
      } catch {}
    }
  } catch {}
}

function killAllElectronProcesses() {
  try {
    if (isWindows) {
      // electron.exe only (packaged Electron apps have different exe names)
      execSync("taskkill /F /T /IM electron.exe", { stdio: ["ignore", "ignore", "ignore"] });
      execSync("taskkill /F /T /IM Electron.exe", { stdio: ["ignore", "ignore", "ignore"] });
      return;
    }

    // macOS / Linux: kill common electron process names
    execSync("pkill -9 Electron", { stdio: ["ignore", "ignore", "ignore"] });
    execSync("pkill -9 electron", { stdio: ["ignore", "ignore", "ignore"] });
  } catch {}
}

function hardCleanupBeforeStart({ masterPort, workerPort }) {
  console.log(`🧹 Cleaning up ports ${masterPort}/${workerPort} and Electron processes...`);
  killListenersByPort(masterPort);
  killListenersByPort(workerPort);
  killAllElectronProcesses();
}

function startForegroundCluster() {
  hardCleanupBeforeStart({ masterPort, workerPort });
  ensureDesktopCommandFile();
  startWorkerOnly({ workerPort }).catch((error) => {
    console.error(`❌ Failed to start worker: ${error.message}`);
    process.exit(1);
  });
}

function executeCommand(cmd) {
  switch (cmd) {
    case "start":
      startForegroundCluster();
      break;
    case "stop":
      stop().catch((error) => {
        console.error(`❌ Failed to stop cicy worker: ${error.message}`);
        process.exit(1);
      });
      break;
    case "status":
      status().catch((error) => {
        console.error(`❌ Failed to get cicy worker status: ${error.message}`);
        process.exit(1);
      });
      break;
    case "restart":
      restart().catch((error) => {
        console.error(`❌ Failed to restart cicy worker: ${error.message}`);
        process.exit(1);
      });
      break;
    case "logs":
      logs();
      break;
    default:
      console.log(`Unknown command: ${cmd}`);
      console.log("Usage: cicy <start|stop|status|restart|logs>");
      process.exit(1);
  }
}

function ensureDesktopCommandFile() {
  if (!fs.existsSync(PROJECT_COMMAND_FILE)) {
    return;
  }

  fs.copyFileSync(PROJECT_COMMAND_FILE, DESKTOP_COMMAND_FILE);
  fs.chmodSync(DESKTOP_COMMAND_FILE, 0o755);
  console.log(`📎 Synced launcher to ${DESKTOP_COMMAND_FILE}`);
}

function prefixLines(prefix, text) {
  return text
    .split(/\r?\n/)
    .filter(Boolean)
    .map((line) => `${prefix} ${line}`)
    .join("\n");
}

function pipeOutput(stream, prefix, onChunk) {
  if (!stream) return;
  stream.on("data", (chunk) => {
    const text = chunk.toString();
    const output = prefixLines(prefix, text);
    if (output) console.log(output);
    if (onChunk) onChunk(text);
  });
}

function waitForMasterReady(child, port) {
  return new Promise((resolve, reject) => {
    const expected = `[Master] listening on http://localhost:${port}`;
    let settled = false;

    const timer = setTimeout(() => {
      if (settled) return;
      settled = true;
      reject(new Error(`Master did not become ready within ${READY_TIMEOUT_MS}ms`));
    }, READY_TIMEOUT_MS);

    const finish = (error) => {
      if (settled) return;
      settled = true;
      clearTimeout(timer);
      if (error) reject(error);
      else resolve();
    };

    const onChunk = (text) => {
      if (text.includes(expected)) {
        finish();
      }
    };

    pipeOutput(child.stdout, "[master]", onChunk);
    pipeOutput(child.stderr, "[master]", onChunk);

    child.once("exit", (code, signal) => {
      finish(new Error(`Master exited before ready (code=${code}, signal=${signal})`));
    });
  });
}

function terminateChild(child, signal) {
  if (!child || child.exitCode !== null || child.killed) {
    return;
  }
  try {
    child.kill(signal);
  } catch {}
}

function waitForExit(child) {
  return new Promise((resolve) => {
    if (!child || child.exitCode !== null) {
      resolve();
      return;
    }
    child.once("exit", () => resolve());
  });
}

async function shutdownChildren(workerChild, masterChild) {
  terminateChild(workerChild, "SIGTERM");
  terminateChild(masterChild, "SIGTERM");

  await Promise.race([
    Promise.all([waitForExit(workerChild), waitForExit(masterChild)]),
    new Promise((resolve) => setTimeout(resolve, SHUTDOWN_TIMEOUT_MS)),
  ]);

  terminateChild(workerChild, "SIGKILL");
  terminateChild(masterChild, "SIGKILL");
}

async function fetchJson(url, options = {}) {
  const response = await fetch(url, options);
  const data = await response.json().catch(() => ({}));
  if (!response.ok) {
    throw new Error(data.error || `Request failed: ${response.status}`);
  }
  return data;
}

async function checkMaster(masterBaseUrl) {
  try {
    await fetchJson(`${masterBaseUrl}/api/ping`);
    return true;
  } catch {
    return false;
  }
}

async function getWorkers(masterBaseUrl) {
  try {
    const data = await fetchJson(`${masterBaseUrl}/api/workers`);
    return data.workers || [];
  } catch {
    return [];
  }
}

async function findReusableWorker(masterBaseUrl, workerPort, timeoutMs = 8000) {
  const startedAt = Date.now();
  while (Date.now() - startedAt < timeoutMs) {
    const worker = selectWorker(await getWorkers(masterBaseUrl), workerPort);
    if (worker && (await checkWorker(worker))) {
      return worker;
    }
    await new Promise((resolve) => setTimeout(resolve, 1000));
  }
  return null;
}

function selectWorker(workers, workerPort) {
  const ranked = workers.filter((worker) => worker?.baseUrl);
  if (!ranked.length) return null;

  const exact = ranked.find(
    (worker) =>
      worker.baseUrl.endsWith(`:${workerPort}`) &&
      worker.registered &&
      (worker.status === "online" || worker.healthStatus === "online")
  );
  if (exact) return exact;

  const online = ranked.find(
    (worker) =>
      worker.registered && (worker.status === "online" || worker.healthStatus === "online")
  );
  return online || null;
}

async function checkWorker(worker) {
  if (!worker?.baseUrl) return false;
  try {
    await fetchJson(`${worker.baseUrl}/observability/healthz`);
    return true;
  } catch {
    return false;
  }
}

function resolveWorkerAuthToken(worker) {
  if (!worker?.baseUrl) return "";

  try {
    const config = JSON.parse(fs.readFileSync(GLOBAL_CONFIG_FILE, "utf8"));
    const nodes = Object.values(config.cicyDesktopNodes || {});
    const matchedNode = nodes.find((node) => node?.base_url === worker.baseUrl);
    return matchedNode?.api_token || config.api_token || "";
  } catch {
    return "";
  }
}

async function callWorkerTool(worker, toolName, payload = {}) {
  const authToken = resolveWorkerAuthToken(worker);
  if (!authToken) {
    throw new Error(`No auth token available for worker ${worker.workerId || worker.baseUrl}`);
  }

  return fetchJson(`${worker.baseUrl}/rpc/${toolName}`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      Authorization: `Bearer ${authToken}`,
    },
    body: JSON.stringify(payload),
  });
}

function parseToolText(response) {
  const text = response?.result?.content?.find((item) => item.type === "text")?.text;
  if (!text) return null;
  return text;
}

async function focusExistingWorker(worker, workerBaseUrl, workerUiUrl) {
  const windowsResponse = await callWorkerTool(worker, "get_windows", {});
  const text = parseToolText(windowsResponse);
  const windows = text ? JSON.parse(text) : [];
  const targetWindow =
    windows.find((win) => (win.url || "").startsWith(workerBaseUrl)) || windows[0] || null;

  if (targetWindow) {
    if (!String(targetWindow.url || "").startsWith(workerBaseUrl)) {
      await callWorkerTool(worker, "load_url", { win_id: targetWindow.id, url: workerUiUrl });
    }

    await callWorkerTool(worker, "control_electron_BrowserWindow", {
      win_id: targetWindow.id,
      code: "(() => { win.show(); if (win.isMinimized()) win.restore(); win.focus(); return true; })()",
    });
    return { reused: true, winId: targetWindow.id };
  }

  await callWorkerTool(worker, "open_window", {
    url: workerUiUrl,
    reuseWindow: true,
    accountIdx: 0,
  });
  return { reused: true, winId: null };
}

async function startWorker({ workerPort, masterBaseUrl, token, workerUiUrl }) {
  const workerChild = spawn(
    isWindows ? "npx.cmd" : "npx",
    ["electron", PACKAGE_ROOT, "--port", String(workerPort), "--url", workerUiUrl],
    {
      cwd: PACKAGE_ROOT,
      shell: isWindows,
      env: {
        ...process.env,
        PORT: String(workerPort),
        CICY_MASTER_URL: masterBaseUrl,
        CICY_MASTER_TOKEN: token,
      },
      stdio: ["ignore", "pipe", "pipe"],
    }
  );

  pipeOutput(workerChild.stdout, "[worker]");
  pipeOutput(workerChild.stderr, "[worker]");
  return workerChild;
}

async function startWorkerOnly({ workerPort }) {
  const tokenManager = new MasterTokenManager();
  const token = tokenManager.getToken();
  const workerUiUrl = `http://localhost:${workerPort}/console/chrome?token=${token}`;

  writeClusterState({
    masterPid: null,
    workerPid: null,
    masterPort,
    workerPort,
    tokenPath: tokenManager.getConfigPath(),
    startedAt: new Date().toISOString(),
  });

  console.log(`🚀 Target worker http://localhost:${workerPort}`);
  console.log(`🪟 Worker UI ${workerUiUrl}`);
  console.log(`📄 Token file: ${tokenManager.getConfigPath()}`);
  console.log("🛑 Press Ctrl+C to stop processes started by this command");

  const workerChild = spawn(
    isWindows ? "npx.cmd" : "npx",
    ["electron", PACKAGE_ROOT, "--port", String(workerPort), "--url", workerUiUrl],
    {
      cwd: PACKAGE_ROOT,
      shell: isWindows,
      env: {
        ...process.env,
        PORT: String(workerPort),
      },
      stdio: ["ignore", "pipe", "pipe"],
    }
  );

  pipeOutput(workerChild.stdout, "[worker]");
  pipeOutput(workerChild.stderr, "[worker]");

  writeClusterState({
    masterPid: null,
    workerPid: workerChild.pid,
    masterPort,
    workerPort,
    tokenPath: tokenManager.getConfigPath(),
    startedAt: new Date().toISOString(),
  });

  let shuttingDown = false;

  const handleShutdown = async (exitCode) => {
    if (shuttingDown) return;
    shuttingDown = true;
    await shutdownChildren(workerChild, null);
    clearClusterState();
    process.exit(exitCode);
  };

  process.on("SIGINT", () => {
    handleShutdown(0);
  });
  process.on("SIGTERM", () => {
    handleShutdown(0);
  });

  workerChild.once("exit", async (code, signal) => {
    if (shuttingDown) return;
    console.error(`❌ Worker exited (code=${code}, signal=${signal})`);
    await handleShutdown(code || 1);
  });
}

async function startMasterCluster({ masterPort, workerPort }) {
  const tokenManager = new MasterTokenManager();
  const token = tokenManager.getToken();
  const masterBaseUrl = `http://localhost:${masterPort}`;
  // Don't open the master UI by default; open the worker UI instead.
  const workerUiUrl = `http://localhost:${workerPort}/console/chrome?token=${token}`;

  writeClusterState({
    masterPid: null,
    workerPid: null,
    masterPort,
    workerPort,
    tokenPath: tokenManager.getConfigPath(),
    startedAt: new Date().toISOString(),
  });

  console.log(`🚀 Target master ${masterBaseUrl}`);
  console.log(`🚀 Target worker http://localhost:${workerPort}`);
  console.log(`🪟 Worker UI ${workerUiUrl}`);
  console.log(`📄 Token file: ${tokenManager.getConfigPath()}`);

  const masterRunning = await checkMaster(masterBaseUrl);
  if (masterRunning) {
    const worker = await findReusableWorker(masterBaseUrl, workerPort);
    if (worker) {
      await focusExistingWorker(worker, `http://localhost:${workerPort}`, workerUiUrl);
      console.log("✅ Reused existing master and worker, focused Electron window");
      return;
    }
  }

  console.log("🛑 Press Ctrl+C to stop processes started by this command");

  let masterChild = null;
  if (!masterRunning) {
    console.log(`🚀 Starting master on ${masterBaseUrl}`);
    masterChild = spawn(process.execPath, [MASTER_ENTRY], {
      cwd: PACKAGE_ROOT,
      env: {
        ...process.env,
        MASTER_PORT: String(masterPort),
        CICY_MASTER_TOKEN: token,
      },
      stdio: ["ignore", "pipe", "pipe"],
    });

    writeClusterState({
      masterPid: masterChild.pid,
      workerPid: null,
      masterPort,
      workerPort,
      tokenPath: tokenManager.getConfigPath(),
      startedAt: new Date().toISOString(),
    });

    await waitForMasterReady(masterChild, masterPort);
  } else {
    console.log("♻️ Reusing existing master");
  }

  console.log(`🚀 Starting worker on http://localhost:${workerPort}`);
  const workerChild = await startWorker({ workerPort, masterBaseUrl, token, workerUiUrl });

  writeClusterState({
    masterPid: masterChild?.pid || null,
    workerPid: workerChild.pid,
    masterPort,
    workerPort,
    tokenPath: tokenManager.getConfigPath(),
    startedAt: new Date().toISOString(),
  });

  let shuttingDown = false;

  const handleShutdown = async (exitCode) => {
    if (shuttingDown) return;
    shuttingDown = true;
    await shutdownChildren(workerChild, masterChild);
    clearClusterState();
    process.exit(exitCode);
  };

  process.on("SIGINT", () => {
    handleShutdown(0);
  });
  process.on("SIGTERM", () => {
    handleShutdown(0);
  });

  if (masterChild) {
    masterChild.once("exit", async (code, signal) => {
      if (shuttingDown) return;
      console.error(`❌ Master exited (code=${code}, signal=${signal})`);
      await handleShutdown(code || 1);
    });
  }

  workerChild.once("exit", async (code, signal) => {
    if (shuttingDown) return;
    console.error(`❌ Worker exited (code=${code}, signal=${signal})`);
    await handleShutdown(code || 1);
  });
}

function isRunning(pid) {
  if (!pid) return false;
  try {
    process.kill(pid, 0);
    return true;
  } catch {
    return false;
  }
}

function getClusterLogFiles(workerPort) {
  return [
    path.join(LOGS_DIR, `cicy-desktop-${workerPort}.log`),
    path.join(LOGS_DIR, `cicy-desktop-${DEFAULT_WORKER_PORT}.log`),
  ].filter((filePath, index, list) => list.indexOf(filePath) === index);
}

async function stop() {
  const state = getRunningClusterState();
  if (!state) {
    console.log("❌ cicy worker is not running");
    clearClusterState();
    return;
  }

  const stoppedWorker = await stopPid(state.workerPid, "worker");
  const stoppedMaster = await stopPid(state.masterPid, "master");
  clearClusterState();

  if (stoppedMaster || stoppedWorker) {
    console.log(`✅ cicy worker stopped (pid:${state.workerPid || "-"})`);
  } else {
    console.log("❌ cicy worker is not running");
  }
}

async function status() {
  const state = getRunningClusterState();
  if (!state) {
    console.log("❌ cicy worker is not running");
    return;
  }

  console.log("✅ cicy worker is running");
  console.log(
    `- worker pid: ${state.workerPid || "reused external"} (${state.workerRunning ? "running" : "stopped"})`
  );
  console.log(`- worker url: http://localhost:${state.workerPort}`);
  if (state.tokenPath) {
    console.log(`- token file: ${state.tokenPath}`);
  }
}

async function restart() {
  await stop();
  startForegroundCluster();
}

function logs() {
  const state = getRunningClusterState();
  const workerPortForLogs = state?.workerPort || workerPort;
  const logFiles = getClusterLogFiles(workerPortForLogs).filter((filePath) =>
    fs.existsSync(filePath)
  );

  if (!logFiles.length) {
    console.log("❌ No worker logs found");
    console.log(`- logs dir: ${LOGS_DIR}`);
    console.log(
      `- expected worker log: ${path.join(LOGS_DIR, `cicy-desktop-${workerPortForLogs}.log`)}`
    );
    return;
  }

  if (state) {
    console.log("✅ Following cicy worker logs");
    console.log(`- worker url: http://localhost:${state.workerPort}`);
  } else {
    console.log("⚠️  Worker is not currently running, showing latest available logs");
  }
  logFiles.forEach((filePath) => console.log(`- ${filePath}`));

  const quotedFiles = logFiles.map((filePath) => `"${filePath}"`).join(" ");
  execSync(`tail -f ${quotedFiles}`, { stdio: "inherit" });
}
