#!/bin/bash
# cicy-rpc - 轻量级 MCP RPC 调用工具，默认 YAML 格式

set -o pipefail

VERSION="1.0.5"
CONFIG_FILE=~/global.json

# 从配置读取节点
load_node() {
  local config node_name node_config
  config=$(cat "$CONFIG_FILE" 2>/dev/null) || { echo "❌ Error: $CONFIG_FILE not found"; echo "Run 'cicy-rpc init' to initialize"; exit 1; }
  node_name="${CICY_NODE:-$(echo "$config" | jq -r '.default // "local"')}"
  node_config=$(echo "$config" | jq -r ".nodes[\"$node_name\"] // empty")
  if [ -z "$node_config" ]; then
    echo "❌ Error: node '$node_name' not found in config"
    echo "Available: $(echo "$config" | jq -r '.nodes | keys | join(", ")')"
    exit 1
  fi
  TOKEN=$(echo "$node_config" | jq -r '.api_token')
  CICY_URL=$(echo "$node_config" | jq -r '.base_url')
}

show_help() {
  cat << 'EOF'
cicy-rpc - CiCy Desktop RPC CLI

Usage: cicy-rpc <command> [options]

Commands:
  init                          Initialize config
  tools [--full]                List all tools
  tools <tool_name>             View tool details
  <tool_name> [key=value ...]   Call tool

Options:
  --json, -j                    Use JSON format
  --help, -h                    Show help
  --version, -v                 Show version

Environment:
  CICY_NODE=<name>      Select node (default: from config)
  DEBUG=1                       Debug output

Config: ~/global.json

Examples:
  cicy-rpc ping
  CICY_NODE=mac cicy-rpc ping
  cicy-rpc open_window url=https://example.com
EOF
  exit 0
}

if [ -z "$1" ]; then echo "❌ Error: Missing arguments"; echo ""; show_help; exit 1; fi
if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then show_help; fi
if [ "$1" = "--version" ] || [ "$1" = "-v" ]; then echo "cicy-rpc version $VERSION"; exit 0; fi

# init 命令
if [ "$1" = "init" ]; then
  if [ ! -f "$CONFIG_FILE" ]; then
    # config stored in ~/global.json
    cat > "$CONFIG_FILE" << 'INITEOF'
{
    "default": "local",
    "nodes": {
        "local": {
            "api_token": "",
            "base_url": "http://localhost:8101"
        }
    }
}
INITEOF
    echo "✅ Created: $CONFIG_FILE"
    echo "📝 Edit $CONFIG_FILE to add your api_token"
    exit 0
  fi
  config=$(cat "$CONFIG_FILE")
  default_node=$(echo "$config" | jq -r '.default')
  echo "📁 Config: $CONFIG_FILE"
  echo "🔧 Default node: $default_node"
  echo "📋 Nodes:"
  echo "$config" | jq -r '.nodes | to_entries[] | "  \(.key): \(.value.base_url)"'
  exit 0
fi

# tools 命令
if [ "$1" = "tools" ]; then
  load_node
  RESPONSE=$(curl --noproxy "*" -s -X GET "$CICY_URL/rpc/tools" \
    -H "Accept: application/json" \
    -H "Authorization: Bearer $TOKEN")

  if [ -n "$2" ] && [ "$2" != "--full" ]; then
    TOOL_NAME="$2"
    TOOL_INFO=$(echo "$RESPONSE" | jq -r ".tools[] | select(.name == \"$TOOL_NAME\")")
    if [ -z "$TOOL_INFO" ]; then echo "Error: Tool '$TOOL_NAME' not found"; exit 1; fi
    NAME=$(echo "$TOOL_INFO" | jq -r '.name')
    DESC=$(echo "$TOOL_INFO" | jq -r '.description')
    echo "$NAME - $DESC"
    PROPS=$(echo "$TOOL_INFO" | jq -r 'if .inputSchema.properties == null then "{}" else .inputSchema.properties end')
    REQUIRED=$(echo "$TOOL_INFO" | jq -r 'if .inputSchema.required == null then "" else [.inputSchema.required[]] | join(",") end')
    if [ "$PROPS" != "{}" ] && [ -n "$PROPS" ]; then
      for key in $(echo "$PROPS" | jq -r 'keys[]'); do
        PTYPE=$(echo "$PROPS" | jq -r ".$key.type")
        PDESC=$(echo "$PROPS" | jq -r ".$key.description // \"\"")
        PDEFAULT=$(echo "$PROPS" | jq -r ".$key.default // \"\"")
        if echo ",$REQUIRED," | grep -q ",$key,"; then echo "  - $key* ($PTYPE): $PDESC"
        else echo "  - $key? ($PTYPE): $PDESC"; fi
        [ -n "$PDEFAULT" ] && echo "    default: $PDEFAULT"
      done
    fi
    exit 0
  fi

  if [ "$2" = "--full" ]; then
    for tool in $(echo "$RESPONSE" | jq -r '.tools[] | @base64'); do
      NAME=$(echo "$tool" | base64 -d | jq -r '.name')
      DESC=$(echo "$tool" | base64 -d | jq -r '.description')
      echo "$NAME - $DESC"
      PROPS=$(echo "$tool" | base64 -d | jq -r 'if .inputSchema.properties == null then "{}" else .inputSchema.properties end')
      REQUIRED=$(echo "$tool" | base64 -d | jq -r 'if .inputSchema.required == null then "" else [.inputSchema.required[]] | join(",") end')
      if [ "$PROPS" != "{}" ] && [ -n "$PROPS" ]; then
        for key in $(echo "$PROPS" | jq -r 'keys[]'); do
          PTYPE=$(echo "$PROPS" | jq -r ".$key.type")
          PDESC=$(echo "$PROPS" | jq -r ".$key.description // \"\"")
          if echo ",$REQUIRED," | grep -q ",$key,"; then echo "  - $key* ($PTYPE): $PDESC"
          else echo "  - $key? ($PTYPE): $PDESC"; fi
        done
      fi
    done
  else
    echo "$RESPONSE" | jq -r '.tools[] | .name + " - " + .description'
  fi
  exit 0
fi

USE_JSON=0

if [[ "$1" =~ ^[a-z_]+/[a-z_]+ ]]; then
  METHOD="$1"; shift
  if [ "$1" = "--json" ] || [ "$1" = "-j" ]; then USE_JSON=1; shift; PARAMS="$@"
  else PARAMS_INPUT="$@"; fi
else
  TOOL_NAME="$1"; shift; METHOD="tools/call"
  YAML_PARAMS="name: $TOOL_NAME"
  if [ $# -gt 0 ]; then
    YAML_PARAMS="${YAML_PARAMS}\narguments:"
    for arg in "$@"; do
      if [[ "$arg" =~ ^([a-zA-Z_][a-zA-Z0-9_]*)=(.+)$ ]]; then
        YAML_PARAMS="${YAML_PARAMS}\n  ${BASH_REMATCH[1]}: ${BASH_REMATCH[2]}"
      else echo "❌ Error: Invalid argument format: $arg"; exit 1; fi
    done
  fi
  PARAMS_INPUT=$(echo -e "$YAML_PARAMS")
fi

load_node

if [ "$USE_JSON" = "0" ]; then
  if ! command -v yq &> /dev/null; then echo "❌ Error: yq not found. Install with: pip install yq --break-system-packages"; exit 1; fi
  PARAMS=$(echo "$PARAMS_INPUT" | yq -c . 2>&1) || { echo "❌ Error: Invalid YAML"; echo "$PARAMS"; exit 1; }
  ACCEPT_HEADER="application/yaml"
else
  echo "$PARAMS" | jq empty 2>/dev/null || { echo "❌ Error: Invalid JSON"; exit 1; }
  ACCEPT_HEADER="application/json"
fi

if ! curl --noproxy "*" -s --connect-timeout 2 $CICY_URL/rpc/tools/list \
  -H "Authorization: Bearer $TOKEN" > /dev/null 2>&1; then
  echo "❌ Error: Cannot connect to $CICY_URL"
  exit 1
fi

if [ "$DEBUG" = "1" ]; then
  echo "====== DEBUG ======"
  echo "Node: ${CICY_NODE:-$(jq -r .default "$CONFIG_FILE")}"
  echo "URL: $CICY_URL/rpc/$METHOD"
  echo "Body: $PARAMS"
  echo "==================="
  curl --noproxy "*" -v -X POST $CICY_URL/rpc/$METHOD \
    -H "Content-Type: application/json" -H "Accept: $ACCEPT_HEADER" \
    -H "Authorization: Bearer $TOKEN" -d "$PARAMS" 2>&1
  exit 0
fi

RESPONSE=$(curl --noproxy "*" -s -w "\n%{http_code}" -X POST $CICY_URL/rpc/$METHOD \
  -H "Content-Type: application/json" -H "Accept: $ACCEPT_HEADER" \
  -H "Authorization: Bearer $TOKEN" -d "$PARAMS" 2>&1)

[ $? -ne 0 ] && { echo "❌ Error: curl failed"; echo "$RESPONSE"; exit 1; }

HTTP_CODE=$(echo "$RESPONSE" | tail -n1)
BODY=$(echo "$RESPONSE" | sed '$d')

[ "$HTTP_CODE" != "200" ] && { echo "❌ Error: HTTP $HTTP_CODE"; echo "$BODY"; exit 1; }
echo "$BODY" | jq -e '.error' > /dev/null 2>&1 && { echo "❌ Error:"; echo "$BODY" | jq -r '.error'; exit 1; }

echo "----------------"
if [ "$USE_JSON" = "0" ]; then
  echo "$BODY" | yq -r '.result.content[] | if .type == "text" then .text elif .type == "image" then "Image (\(.mimeType)): \(.data[:100])..." else . end' 2>&1 || { echo "$BODY"; exit 1; }
else
  echo "$BODY" | jq -r '.result.content[] | if .type == "text" then .text elif .type == "image" then "Image (\(.mimeType)): \(.data[:100])..." else . end' 2>&1 || { echo "$BODY"; exit 1; }
fi
echo "----------------"
